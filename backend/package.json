{
  "name": "quadzero-scout-backend",
  "version": "1.0.0",
  "description": "Quadzero Scout Backend - AWS Lambda functions",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy:dev": "cd ../infra && serverless deploy --stage dev",
    "deploy:staging": "cd ../infra && serverless deploy --stage staging",
    "deploy:prod": "cd ../infra && serverless deploy --stage prod",
    "offline": "cd ../infra && serverless offline"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-ses": "^3.700.0",
    "@aws-sdk/client-lambda": "^3.985.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-textract": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@google/generative-ai": "^0.24.1",
    "@sparticuz/chromium": "^143.0.4",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "jose": "^6.1.3",
    "mammoth": "^1.11.0",
    "marked": "^17.0.1",
    "openai": "^4.73.0",
    "pdf-parse": "^1.1.1",
    "puppeteer-core": "^24.34.0",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/bcryptjs": "^2.4.6",
    "@types/marked": "^5.0.2",
    "@types/node": "^22.10.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.16.0",
    "serverless-esbuild": "^1.54.3",
    "serverless-offline": "^14.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
